{
  "rewrites": [
    { "source": "/realms/:id", "destination": "/realms/:id.html" },
    { "source": "/maps/:id", "destination": "/maps/:id.html" },
    { "source": "/wiki/:id", "destination": "/wiki/:id.html" },
    { "source": "/community/:id", "destination": "/community/:id.html" },
    { "source": "/realms", "destination": "/realms.html" },
    { "source": "/maps", "destination": "/maps.html" },
    { "source": "/wiki", "destination": "/wiki.html" },
    { "source": "/community", "destination": "/community.html" }
  ],
  "headers": [
    {
      "source": "**/*.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "**/_next/**",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
